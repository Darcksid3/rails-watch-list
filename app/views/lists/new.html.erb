<main class="container fluid">
    <div class="row justify-content-center mx-auto">
        <div class="col-12 col-lg-8 border border-3 border-info shadowed rounded-5 p-5">
            <div class="bg-secondary rounded p-3">
                <h2 class="text-info">Nouvelle liste</h2>
                <%= simple_form_for [@list] do |f| %>
                    <%= f.input :name, class: "text-info" %>
                    <%= f.submit "crée", class: "btn btn-outline-info" %>
                <% end %>
            </div>
        </div>
    </div>
</main>